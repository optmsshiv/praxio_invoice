# ================================================================
#  OPTMS Invoice Manager — /public_html/.htaccess
# ================================================================

# No directory listing
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ── Block direct access to config/ and includes/ ──────────
    RewriteRule ^config/   - [F,L]
    RewriteRule ^includes/ - [F,L]

    # ── Let real files and folders pass through ────────────────
    # (auth/login.php, api/tenant.php, assets/, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── Everything else → index.php router ────────────────────
    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>

# ── Security Headers ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Block PHP in uploads folder ───────────────────────────────
<IfModule mod_rewrite.c>
    RewriteRule ^assets/uploads/.*\.php$ - [F,L]
</IfModule>